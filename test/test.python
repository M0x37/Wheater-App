# 2. Vorlage laden
# Wir laden die Datei ohne Header, um die ersten Zeilen der Vorlage exakt zu behalten
try:
    df_template = pd.read_excel('vokabelBoxVorlage.xlsx', header=None)
    
    # 3. Neue Vokabeln in ein DataFrame umwandeln
    df_vocab = pd.DataFrame(vocab_data)
    
    # 4. Vorlage und Vokabeln zusammenfügen
    # Die Vokabeln werden einfach unter die Kopfzeilen der Vorlage gehängt
    df_final = pd.concat([df_template, df_vocab], ignore_index=True)
    
    # 5. Speichern
    output_name = "vokabeln_vokabelbox_neu.xlsx"
    df_final.to_excel(output_name, index=False, header=False)
    
    print(f"Datei '{output_name}' wurde erfolgreich erstellt!")

except FileNotFoundError:
    print("Fehler: Die Datei 'vokabelBoxVorlage.xlsx' wurde nicht gefunden.")